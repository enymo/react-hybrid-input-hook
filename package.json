{
  "name": "@enymo/react-hybrid-input-hook",
  "version": "2.0.0",
  "description": "Hook to create inputs that work both as controlled inputs and as part of a react form",
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm",
      "cjs"
    ],
    "dts": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/enymo/react-hybrid-input-hook.git"
  },
  "author": "enymo GmbH",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.0.17",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-hook-form": "^7.34.2"
  }
}
